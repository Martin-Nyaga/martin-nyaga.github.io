---
import { Icon } from 'astro-icon/components';
---
<div x-data="theme" x-cloak class="theme-toggle" @click="toggle">
  <div x-show="!dark"><Icon name="material-symbols:dark-mode" size="18"/></div>
  <div x-show="dark"><Icon name="material-symbols:sunny" size="18"/></div>
</div>

<style>
  .theme-toggle { cursor: pointer; display: inline-flex; color: var(--muted); transition: color .15s, transform .2s; }
  .theme-toggle:hover { color: var(--accent); transform: rotate(35deg); }
</style>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('theme', () => ({
      dark: document.documentElement.classList.contains('dark'),
      toggle() {
        this.dark = !this.dark;
        localStorage.setItem('theme', this.dark ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', this.dark);
      }
    }));
  });
</script>
