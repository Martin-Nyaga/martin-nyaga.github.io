---
// Lucide icon inner-markup (24x24, stroke=currentColor) so each glyph
// inherits the card's colour and carries the gold accent.
const icons = {
  "circuit-board": `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M11 9h4a2 2 0 0 0 2-2V3"/><circle cx="9" cy="9" r="2"/><path d="M7 21v-4a2 2 0 0 1 2-2h4"/><circle cx="15" cy="15" r="2"/>`,
  "chart-column": `<path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/>`,
  "chart-line": `<path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/>`,
  "redis": `<path d="m12 3 8 4-8 4-8-4 8-4Z"/><path d="m4 12 8 4 8-4"/><path d="m4 17 8 4 8-4"/>`,
};
const svg = (name) => `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${icons[name]}</svg>`;

const openSourceProjects = [
  {
    icon: "circuit-board",
    name: "Logisim.app",
    type: "Contributor",
    tech: ["Java", "WebAssembly"],
    url: "https://logisim.app",
    description: "Classic Logisim — the widely used digital logic simulation software — running in the browser powered by WebAssembly."
  },
  {
    icon: "chart-column",
    name: "Fast Statistics",
    type: "Owner",
    tech: ["Ruby", "C++"],
    url: "https://github.com/Martin-Nyaga/fast_statistics",
    description: "A high-performance native Ruby extension (written in C++) for computation of descriptive statistics."
  },
  {
    icon: "chart-line",
    name: "Termplot",
    type: "Owner",
    tech: ["Ruby"],
    url: "https://github.com/Martin-Nyaga/termplot",
    description: "A terminal plotting tool for visualising streaming data."
  },
  {
    icon: "redis",
    name: "Redlock-rb",
    type: "Contributor",
    tech: ["Ruby", "Redis"],
    url: "https://github.com/leandromoreira/redlock-rb",
    description: "Ruby implementation of Redlock, the Redis-based distributed locking algorithm, with over 20M downloads."
  }
]
---
<section id="open-source" class="open-source">
  <div class="section-head">
    <h2 class="title">Open source projects</h2>
    <a class="see-all" href="https://github.com/Martin-Nyaga" target="_blank" rel="noopener">
      See all <span class="arrow" aria-hidden="true">→</span>
    </a>
  </div>

  <div class="cards">
    {openSourceProjects.map(project => (
      <a class="card" href={project.url} target="_blank" rel="noopener">
        <div class="card-head">
          <span class="card-icon" set:html={svg(project.icon)} />
          <span class="card-name">{project.name}</span>
        </div>
        <p class="card-desc">{project.description}</p>
        <div class="card-meta">
          <span class="tech">{project.tech.join(" · ")}</span>
          <span class="role">{project.type}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  /* clear section rhythm after the intro note */
  .open-source { margin-top: 4rem; scroll-margin-top: 1.5rem; }

  /* title left, "see all" callout balanced to the right on a shared baseline */
  .section-head {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
  }
  /* a mid-page section heading — quieter than the home page's lead title */
  .section-head .title { font-size: 1.65rem; margin-bottom: 0.85rem; }

  .cards { display: flex; flex-direction: column; gap: 0.75rem; }

  .card {
    display: block;
    text-decoration: none; color: inherit;
    border: 1px solid var(--rule); border-radius: 4px;
    padding: 1.1rem 1.25rem;
    transition: border-color .2s ease, transform .2s ease;
  }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); }

  .card-head { display: flex; align-items: center; gap: 0.65rem; margin-bottom: 0.35rem; }

  /* icon: gold by default, inherits via currentColor */
  .card-icon { flex: 0 0 auto; line-height: 0; color: var(--accent); }
  .card-icon :global(svg) { width: 20px; height: 20px; display: block; }

  .card-name {
    color: var(--text);
    font-family: "Crimson Pro", Georgia, serif; font-weight: 500; font-size: 1.35rem;
    line-height: 1.15; letter-spacing: -0.01em;
  }
  .card-desc { margin: 0; font-size: 0.92rem; color: var(--muted); line-height: 1.55; }

  /* meta row: technologies (left) balanced against the role tag (right) */
  .card-meta {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    margin-top: 0.7rem;
  }
  .tech {
    font-family: "Fragment Mono", monospace; font-size: 0.7rem; letter-spacing: 0.01em;
    color: var(--muted);
  }
  .role {
    font-family: "Fragment Mono", monospace; font-size: 0.62rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--muted); white-space: nowrap;
  }

  /* gold mono-caps callout to the full list on GitHub — the row's one accent */
  .see-all {
    flex: 0 0 auto;
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-family: "Fragment Mono", monospace; font-size: 0.72rem; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--accent); text-decoration: none;
    transition: opacity .2s ease;
  }
  .see-all:hover { opacity: 0.7; }
  .see-all .arrow { transition: transform .2s ease; }
  .see-all:hover .arrow { transform: translateX(3px); }
</style>
