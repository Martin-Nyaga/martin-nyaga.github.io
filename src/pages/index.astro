---
import Layout from '../layouts/Layout.astro';
import OpenSource from '../components/OpenSource.astro';
import PgpKeyVariants from '../components/PgpKeyVariants.astro';
import { Icon } from 'astro-icon/components';
---
<Layout>
  <main class="hero">
    <div class="marker">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19h8"/><path d="m4 17 6-6-6-6"/>
      </svg>
    </div>
    <h1 class="title">Hi, I’m Martin</h1>
    <div class="prose">
      <p>
        I’m a software engineer based in Leeds, UK, originally from Nairobi, Kenya.
        I wrote my first line of code in 2010. Since then, I’ve built complex
        systems across enterprise software, constrained industrial environments,
        consumer mobile apps, and B2B SaaS.
      </p>

      <div class="profile-links icon-links" aria-label="Profile links">
        <a class="icon-link" href="https://github.com/Martin-Nyaga" target="_blank" rel="noopener">
          <Icon name="mdi:github" size="18" />
          <span>GitHub</span>
        </a>
        <span class="sep">·</span>
        <a class="icon-link" href="https://www.linkedin.com/in/martin-nyaga/" target="_blank" rel="noopener">
          <Icon name="mdi:linkedin" size="18" />
          <span>LinkedIn</span>
        </a>
      </div>

      <section class="intro-section">
        <h2>Now</h2>
        <ul class="chevron-list">
          <li>
            <svg class="bullet-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6" />
            </svg>
            <span>
              Lead Software Developer at
              <a class="link" target="_blank" rel="noopener" href="https://drs.software/">DRS Software</a>.
            </span>
          </li>
          <li>
            <svg class="bullet-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6" />
            </svg>
            <span>
              Co-founder of
              <a class="link" target="_blank" rel="noopener" href="https://mentorbyperforma.com/">Performa</a>,
              building AI-powered gym and fitness software.
            </span>
          </li>
        </ul>
      </section>

      <section class="intro-section">
        <h2>Some highlights</h2>
        <ul class="chevron-list">
          <li>
            <svg class="bullet-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6" />
            </svg>
            <span>
              Modernised a
              <a class="link" target="_blank" rel="noopener" href="https://drs.software/work/enterprise-it-modernisation/">
                large-scale C++ application</a>
              into a WebAssembly + TypeScript web platform for a Fortune 500
              company. We went from proof-of-concept to worldwide production
              rollout in under 12 months.
            </span>
          </li>
          <li>
            <svg class="bullet-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6" />
            </svg>
            <span>
              Built an
              <a class="link" target="_blank" rel="noopener" href="https://drs.software/work/vpi">
                industrial analytics platform</a>
              now running in a couple massive petroleum refineries. Synthesising
              tens of gigabytes of process data with second-level latency was fun.
            </span>
          </li>
          <li>
            <svg class="bullet-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6" />
            </svg>
            <span>
              Won an
              <a class="link" target="_blank" rel="noopener" href="https://drs.software/blog/iuk-smart-grant/">
                Innovate UK SMART Grant</a>
              to build real-time ML for process plants, with the resulting
              models reaching 95% accuracy in live control loops.
            </span>
          </li>
          <li>
            <svg class="bullet-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6" />
            </svg>
            <span>
              Named a
              <a class="link" target="_blank" rel="noopener" href="https://drs.software/blog/drs-shortlisted-for-two-leeds-digital-festival-awards-2025/">
                2× Leader of the Year finalist</a>
              at Leeds Digital Festival, and one of
              <a class="link" target="_blank" rel="noopener" href="https://www.linkedin.com/feed/update/urn:li:activity:7308463613650878465/">
                Leeds &amp; West Yorkshire’s Top 30 Under 30</a>
              in 2025.
            </span>
          </li>
          <li>
            <svg class="bullet-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6" />
            </svg>
            <span>
              Long ago, I co-founded and ran a software consultancy in Nairobi,
              Kenya.
            </span>
          </li>
        </ul>
      </section>
    </div>

    <OpenSource />
    <PgpKeyVariants />
  </main>
</Layout>

<style>
  .intro-section {
    margin-top: 4rem;
  }

  .profile-links {
    margin-top: 1.75rem;
  }

  .intro-section h2 {
    margin: 0 0 0.85rem;
    font-family: "Crimson Pro", Georgia, serif;
    font-size: 1.65rem;
    font-weight: 500;
    line-height: 1.15;
    color: var(--text);
  }

  .chevron-list {
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .chevron-list li {
    display: grid;
    grid-template-columns: 1rem 1fr;
    gap: 0.5rem;
    align-items: start;
  }

  .chevron-list .bullet-icon {
    width: 1rem;
    height: 1rem;
    margin-top: 0.35rem;
    color: var(--accent);
  }

  @media (max-width: 520px) {
    .chevron-list li { gap: 0.4rem; }
  }
</style>
